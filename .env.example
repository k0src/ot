# =============================================================================
# OTI Workspace — example environment variables (NON-SECRET PLACEHOLDERS ONLY)
# Copy to .env and fill in for local development. NEVER commit real secrets.
# Outbound Azure calls use managed identity (DefaultAzureCredential), not keys.
# Real secrets (ADO PAT, embeddings key) live in Azure Key Vault.
# =============================================================================

# ---- Shared ----
NODE_ENV=development

# ---- Backend: server ----
PORT=3000

# ---- Backend: database (local dev uses Azure SQL Edge in Docker) ----
# Dev-only SA password is set in docker-compose; not a real secret.
DATABASE_URL=sqlserver://localhost:1433;database=oti;user=sa;password=Your_dev_password123;encrypt=true;trustServerCertificate=true

# ---- Entra ID (Azure AD) — backend JWT validation ----
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_API_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_API_AUDIENCE=api://oti-workspace

# ---- Azure OpenAI / AI Foundry (endpoints + deployment names, no keys) ----
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_GPT5=gpt-5
AZURE_OPENAI_DEPLOYMENT_GPT5_MINI=gpt-5-mini
AZURE_OPENAI_DEPLOYMENT_EMBEDDINGS=text-embedding-3-large
AZURE_AI_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com

# ---- Azure AI Search (RAG / knowledge base) ----
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_INDEX_NAME=oti-evidence

# ---- Azure Blob Storage (evidence files) ----
AZURE_STORAGE_ACCOUNT_URL=https://yourstorage.blob.core.windows.net
AZURE_STORAGE_CONTAINER=evidence

# ---- Azure Key Vault (holds the few real secrets) ----
AZURE_KEY_VAULT_URL=https://your-kv.vault.azure.net

# ---- Application Insights (telemetry) ----
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000

# ---- Azure DevOps (read-only; PAT is stored in Key Vault) ----
ADO_ORG_URL=https://dev.azure.com/your-org
ADO_PROJECT=your-project

# ---- Frontend (Vite — must be prefixed VITE_) ----
VITE_API_BASE_URL=http://localhost:3000
VITE_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
VITE_ENTRA_SPA_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_ENTRA_API_SCOPE=api://oti-workspace/access_as_user
VITE_ENTRA_REDIRECT_URI=http://localhost:5173
